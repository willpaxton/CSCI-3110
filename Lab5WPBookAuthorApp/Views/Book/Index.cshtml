@{
    ViewData["Title"] = "Books";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Books</h1>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add New Book
        </a>
    </div>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4" id="bookContainer">
    </div>
</div>

<div id="bookModalContainer">
    <partial name="_BookDetailsModal.cshtml" />
</div>

<div id="authorModalContainer">
    <partial name="_AuthorModal.cshtml" />
</div>

@section Scripts{
    <script type="module" src="~/js/bookIndex.js"></script>
}
